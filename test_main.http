GET http://127.0.0.1:8000/routes
Accept: application/json
Authorization: Bearer {{access_token}}

###

GET http://127.0.0.1:8000/routes?search=harbor
Accept: application/json
Authorization: Bearer {{access_token}}

###

GET http://127.0.0.1:8000/routes/{{route_id}}
Accept: application/json
Authorization: Bearer {{access_token}}

###

GET http://127.0.0.1:8000/routes/{{route_id}}/map
Accept: application/json
Authorization: Bearer {{access_token}}

###

PATCH http://127.0.0.1:8000/routes/{{route_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "distance_km": 20,
  "estimated_duration_minutes": 55
}

###

DELETE http://127.0.0.1:8000/routes/{{route_id}}
Accept: application/json
Authorization: Bearer {{access_token}}
