}

###

GET http://127.0.0.1:8000/auth/me
Accept: application/json
Authorization: Bearer {{access_token}}

###

GET http://127.0.0.1:8000/auth/sessions
Accept: application/json
Authorization: Bearer {{access_token}}

###

PATCH http://127.0.0.1:8000/auth/me
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "full_name": "Main Depot Admin"
}

###

POST http://127.0.0.1:8000/auth/logout
Accept: application/json
Authorization: Bearer {{access_token}}

###

POST http://127.0.0.1:8000/auth/logout-all
Accept: application/json
Authorization: Bearer {{access_token}}

###

GET http://127.0.0.1:8000/auth/users
Accept: application/json
Authorization: Bearer {{access_token}}

###

POST http://127.0.0.1:8000/auth/users
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "email": "manager@srmss.local",
  "password": "Passw0rd!",
  "full_name": "Ops Manager",
  "role": "manager"
}

###

GET http://127.0.0.1:8000/auth/users/{{user_id}}
Accept: application/json
Authorization: Bearer {{access_token}}

###

PATCH http://127.0.0.1:8000/auth/users/{{user_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "role": "manager"
}

###

DELETE http://127.0.0.1:8000/auth/users/{{user_id}}
Accept: application/json
Authorization: Bearer {{access_token}}

